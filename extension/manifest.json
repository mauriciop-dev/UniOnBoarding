{
  "manifest_version": 3,
  "name": "ProOnboarding",
  "version": "0.1.4",
  "description": "Onboarding universal para cualquier web: explica la pagina y te guia paso a paso con audio y resaltado visual.",
  "action": {
    "default_title": "Abrir ProOnboarding"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://uni-on-boarding-idcs.vercel.app/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
