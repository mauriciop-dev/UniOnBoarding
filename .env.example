# ProOnboarding API - environment variables template
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local to git.

# AI providers (in fallback order: GEMINI -> GROQ -> DEEPSEEK)
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# InsForge backend (cache + future features)
INSFORGE_URL=https://your-app.region.insforge.app
INSFORGE_API_KEY=ik_your_project_key
INSFORGE_ANON_KEY=eyJ...
